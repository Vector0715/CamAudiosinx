<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Kamera preview -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Yozuv holati indikatori -->
    <TextView
        android:id="@+id/recordingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:background="@color/overlay_dark"
        android:text="@string/recording"
        android:textColor="@color/accent_red"
        android:textStyle="bold"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Chap tomondagi musiqa menyu tugmasi -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnSelectMusic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:contentDescription="@string/select_music"
        android:src="@android:drawable/ic_menu_add"
        app:backgroundTint="@color/menu_bg"
        app:tint="@color/white"
        app:fabSize="normal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="60dp" />

    <!-- Tanlangan musiqa nomi (chap menyu ostida chiqadi) -->
    <TextView
        android:id="@+id/txtSelectedMusic"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@color/overlay_dark"
        android:padding="8dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:text="@string/no_music_selected"
        app:layout_constraintTop_toBottomOf="@id/btnSelectMusic"
        app:layout_constraintStart_toStartOf="@id/btnSelectMusic"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Ovoz to'lqini (waveform) - gorizontal, real vaqtda -->
    <com.example.cameramusicapp.ui.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_marginBottom="140dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- O'rtadagi Play/Stop tugmasi -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnPlayRecord"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_marginBottom="30dp"
        android:src="@android:drawable/ic_media_play"
        app:backgroundTint="@color/accent_green"
        app:tint="@color/black"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Pastki o'ng: kamera almashtirish -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnSwitchCamera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="38dp"
        android:contentDescription="@string/switch_camera"
        android:src="@android:drawable/ic_menu_rotate"
        app:backgroundTint="@color/menu_bg"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
